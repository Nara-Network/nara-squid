{
  "name": "protocol-squid",
  "private": true,
  "scripts": {
    "build": "rm -rf lib && tsc",
    "prepare": "husky install",
    "postinstall": "npx husky install",
    "format": "prettier . --write **/*.{js,ts,json} --ignore-path .prettierignore",
    "test": "mocha -r ts-node/register/transpile-only -r tsconfig-paths/register 'src/test/**/*.test.ts'",
    "migrate": "sqd down && sqd typegen && sqd codegen && sqd build && sqd up && sqd migration:generate && sqd migration:apply",
    "squid:ethereum": "npm run migrate && sqd process:ethereum",
    "squid:ethereumSepolia": "npm run migrate && sqd process:ethereumSepolia",
    "squid": "npm run squid:ethereum"
  },
  "dependencies": {
    "@subsquid/archive-registry": "^3.3.2",
    "@subsquid/big-decimal": "^1.0.0",
    "@subsquid/evm-processor": "^1.21.2",
    "@subsquid/graphql-server": "^4.8.0",
    "@subsquid/typeorm-migration": "^1.3.0",
    "@subsquid/typeorm-store": "^1.5.1",
    "axios": "1.6.8",
    "date-fns": "^4.1.0",
    "dotenv": "^16.1.4",
    "ethers": "^6.5.1",
    "lru-cache": "^11.1.0",
    "luxon": "^3.4.4",
    "pg": "^8.11.0",
    "type-graphql": "^1.2.0-rc.1",
    "typeorm": "^0.3.16",
    "viem": "^2.21.42"
  },
  "devDependencies": {
    "@subsquid/evm-typegen": "^4.3.0",
    "@subsquid/typeorm-codegen": "^2.0.2",
    "@types/chai": "^5.0.1",
    "@types/luxon": "^3.4.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.67",
    "chai": "^5.1.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "mocha": "^11.0.1",
    "prettier": "3.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.1.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,ts,json,md}": "npx prettier . --write --ignore-path .prettierignore"
  }
}
